    "studentService": {
      "baseUrl": "http://localhost:8082",
      "endpoints": {
        "getCourses": {
          "method": "GET",
          "endpoint": "/student/courses",
          "description": "Get student's enrolled courses",
          "headers": {
            "Authorization": "Bearer <studentToken>"
          }
        },
        "enrollInCourse": {
          "method": "POST",
          "endpoint": "/student/enroll",
          "description": "Enroll in a course",
          "headers": {
            "Authorization": "Bearer <studentToken>",
            "Content-Type": "application/json"
          },
          "requestBody": {
            "courseCode": "MATH101"
          },
          "response": {
            "success": true,
            "message": "Enrolled in course successfully"
          }
        },
        "getMaterials": {
          "method": "GET",
          "endpoint": "/student/materials/{courseCode}",
          "description": "Get course materials",
          "headers": {
            "Authorization": "Bearer <studentToken>"
          }
        },
        "getAssignments": {
          "method": "GET",
          "endpoint": "/student/assignments/{courseCode}",
          "description": "Get assignments for a course",
          "headers": {
            "Authorization": "Bearer <studentToken>"
          }
        },
        "uploadAssignment": {
          "method": "POST",
          "endpoint": "/student/assignments/upload",
          "description": "Upload assignment submission",
          "headers": {
            "Authorization": "Bearer <studentToken>",
            "Content-Type": "multipart/form-data"
          },
          "requestBody": {
            "assignmentId": 1,
            "file": "<file_data>",
            "comments": "Assignment submission"
          }
        },
        "getGrades": {
          "method": "GET",
          "endpoint": "/student/grades",
          "description": "Get student's grades",
          "headers": {
            "Authorization": "Bearer <studentToken>"
          }
        },
        "getAttendance": {
          "method": "GET",
          "endpoint": "/student/attendance",
          "description": "Get student's attendance records",
          "headers": {
            "Authorization": "Bearer <studentToken>"
          },
          "queryParams": {
            "studentId": 7
          }
        }
      }
    },
