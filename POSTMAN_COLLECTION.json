  "item": [
    {
      "name": "1. Authentication (Identity Service :8081)",
      "description": "Login endpoints for all roles with updated passwords and email-based authentication",
      "item": [
        {
          "name": "Login - Operator",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"operator@edulink.com\",\n  \"password\": \"Operator@123\"\n}"}
          }
        },
        {
          "name": "Login - School Admin",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@greenwood.edu\",\n  \"password\": \"Admin@1234\"\n}"}
          }
        },
        {
          "name": "Login - Teacher",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"teacher@greenwood.edu\",\n  \"password\": \"Teacher@123\"\n}"}
          }
        },
        {
          "name": "Login - Student",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"student@greenwood.edu\",\n  \"password\": \"Student@123\"\n}"}
          }
        },
        {
          "name": "Login - Board Officer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"boardofficer@edulink.com\",\n  \"password\": \"Board@1234\"\n}"}
          }
        },
        {
          "name": "Login - Compliance Officer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"compliance@edulink.com\",\n  \"password\": \"Comply@1234\"\n}"}
          }
        },
        {
          "name": "Login - Regulator",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"regulator@edulink.com\",\n  \"password\": \"Regul@1234\"\n}"}
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{identity_url}}/auth/change-password",
            "body": {"mode": "raw", "raw": "{\n  \"currentPassword\": \"Student@123\",\n  \"newPassword\": \"NewPass@456\",\n  \"confirmPassword\": \"NewPass@456\"\n}"}
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{identity_url}}/auth/refresh-token",
            "body": {"mode": "raw", "raw": "{\n  \"refreshToken\": \"YOUR_REFRESH_TOKEN_HERE\"\n}"}
          }
        }
      ]
    },
