            ],
            "url": "{{notification_url}}/notifications/send",
            "body": {"mode": "raw", "raw": "{\n  \"recipientId\": \"student@greenwood.edu\",\n  \"recipientEmail\": \"student@greenwood.edu\",\n  \"recipientRole\": \"STUDENT\",\n  \"title\": \"Assignment Due Tomorrow\",\n  \"message\": \"Reminder: Algebra Assignment 1 is due tomorrow at 11:59 PM\",\n  \"type\": \"ALERT\"\n}"}
