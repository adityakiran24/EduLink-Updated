          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "{{identity_url}}/operator/users?role=EDUCATION_BOARD_OFFICER", "host": ["{{identity_url}}"], "path": ["operator", "users"], "query": [{"key": "role", "value": "EDUCATION_BOARD_OFFICER"}]}
