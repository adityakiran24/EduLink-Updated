  "variable": [
    {"key": "identity_url", "value": "http://localhost:8081"},
    {"key": "student_url", "value": "http://localhost:8082"},
    {"key": "course_url", "value": "http://localhost:8083"},
    {"key": "exam_url", "value": "http://localhost:8084"},
    {"key": "attendance_url", "value": "http://localhost:8085"},
    {"key": "compliance_url", "value": "http://localhost:8086"},
